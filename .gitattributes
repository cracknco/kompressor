# Git LFS tracking for test fixtures <= 2 MB.
# Larger fixtures are stored in R2 and fetched by scripts/fetch-fixtures.sh.
# See docs/adr/001-fixture-storage.md for the storage strategy.

# Audio fixtures (small samples)
fixtures/**/*.aac filter=lfs diff=lfs merge=lfs -text
fixtures/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
